# apps/api/.env
# In production the API refuses to boot on the public dev defaults: set a real JWT_SECRET (≥32 chars)
# and a real MP_ACCESS_TOKEN. Set MP_WEBHOOK_SECRET to enable MercadoPago webhook signature verification.
DATABASE_URL="file:./dev.db"
PORT=4000
PUBLIC_WEB_URL="http://localhost:5173"
PUBLIC_API_URL="http://localhost:4000"
JWT_SECRET="change-me-long-random"
ADMIN_EMAIL="resolutecontacto@gmail.com"
ADMIN_PASSWORD="change-me-strong"
MP_ACCESS_TOKEN="APP_USR-..."
MP_PUBLIC_KEY="APP_USR-..."
MP_WEBHOOK_SECRET=""
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER="resolutecontacto@gmail.com"
SMTP_PASS="gmail-app-password"
MAIL_FROM="Resolute Force <resolutecontacto@gmail.com>"
ADMIN_NOTIFY_EMAIL="resolutecontacto@gmail.com"

# PAQ.AR / Correo Argentino (gestión de envíos en el admin). API-Key + agreement los entrega
# el área Comercial de Correo Argentino. Sin estos valores la sección "Correo" del admin queda
# deshabilitada ("PAQ.AR no configurado"); el resto de la tienda funciona igual.
# En producción cambiar PAQAR_BASE_URL a https://api.correoargentino.com.ar/paqar
PAQAR_BASE_URL="https://apitest.correoargentino.com.ar/paqar"
PAQAR_API_KEY=""
PAQAR_AGREEMENT=""

# apps/web/.env
VITE_API_URL="http://localhost:4000"
VITE_MP_PUBLIC_KEY="APP_USR-..."
