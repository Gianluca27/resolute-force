generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id            String      @id @default(cuid())
  slug          String      @unique
  line          String
  color         String
  dotColor      String
  tag           String?
  price         Int
  imageUrl      String
  imagePublicId String?
  active        Boolean     @default(true)
  sortOrder     Int         @default(0)
  variants      Variant[]
  orderItems    OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Variant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  size      String
  stock     Int     @default(0)

  @@unique([productId, size])
}

model Order {
  id             String      @id @default(cuid())
  orderNo        String      @unique
  customerName   String
  customerEmail  String
  customerPhone  String?
  address        String
  city           String
  paymentMethod  String
  status         String      @default("pending")
  subtotal       Int
  discount       Int         @default(0)
  total          Int
  mpPaymentId    String?
  mpPreferenceId String?
  // Dirección estructurada para PAQ.AR (nullable: pedidos previos al checkout estructurado
  // solo tienen address/city libres; el admin completa estos campos al generar el envío).
  shippingStreet       String?
  shippingStreetNumber String?
  shippingFloor        String?
  shippingApartment    String?
  shippingZip          String?
  shippingProvince     String?
  shipment       Shipment?
  items          OrderItem[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

// Envío registrado en Correo Argentino vía PAQ.AR. 1:1 con Order: si se cancela y se
// regenera, la fila se reutiliza (el TN anterior queda solo en el historial del correo).
model Shipment {
  id             String   @id @default(cuid())
  orderId        String   @unique
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  trackingNumber String   @unique
  status         String   @default("created") // created | cancelled
  deliveryType   String // homeDelivery | agency | locker
  agencyId       String?
  serviceType    String
  weightGrams    Int
  heightCm       Int
  widthCm        Int
  depthCm        Int
  declaredValue  Int
  paqarResponse  Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Remitente + defaults de paquete para el alta de órdenes PAQ.AR. Fila única editable en admin.
model ShippingConfig {
  id                 Int      @id @default(1)
  senderName         String
  senderEmail        String   @default("")
  senderPhone        String   @default("")
  senderStreet       String
  senderStreetNumber String
  senderFloor        String   @default("")
  senderApartment    String   @default("")
  senderCity         String
  senderProvince     String
  senderZip          String
  defaultWeightGrams Int      @default(500)
  defaultHeightCm    Int      @default(10)
  defaultWidthCm     Int      @default(30)
  defaultDepthCm     Int      @default(40)
  defaultServiceType String   @default("CP")
  labelFormat        String   @default("10x15")
  updatedAt          DateTime @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  line      String
  color     String
  size      String
  unitPrice Int
  qty       Int
}

model DropConfig {
  id        Int      @id @default(1)
  targetAt  DateTime
  visible   Boolean  @default(true)
  title     String   @default("Algo se está forjando")
  teaser    String
  updatedAt DateTime @updatedAt
}

model SiteContent {
  id                  Int      @id @default(1)
  marquee             String
  heroKicker          String
  heroTitle1          String
  heroTitle2          String
  heroSubtitle        String
  transferDiscountPct Int      @default(10)
  bankAlias           String   @default("")
  bankCbu             String   @default("")
  contactWhatsapp     String
  contactInstagram    String
  contactEmail        String
  contactLocation     String
  updatedAt           DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Visit {
  id        String   @id @default(cuid())
  path      String
  createdAt DateTime @default(now())
}
